APP_MODE=server
CARDGRADER_UID=1000
CARDGRADER_GID=1000

FRONTEND_PORT=8711
BACKEND_PORT=8710
VITE_API_BASE_URL=http://YOUR-SERVER-IP:8710

# CORS_ORIGINS must include the exact frontend origin users open in the browser.
# If users open http://192.168.1.103:8711, that exact origin must be present.
# If you later use a domain, add that domain origin here too.
CORS_ORIGINS=http://YOUR-SERVER-IP:8711,http://lajos-server:8711,http://localhost:8711,http://127.0.0.1:8711

DATABASE_URL=sqlite:////app/data/cardgrader.db
DATA_DIR=/app/data
MEDIA_DIR=/app/media
CATALOG_DIR=/app/catalog
LOG_DIR=/app/logs

LOCAL_AI_MODE=remote_worker
LOCAL_AI_WORKER_BASE_URL=http://YOUR-WINDOWS-TAILSCALE-IP:8765
LOCAL_AI_MODEL_NAME=
AI_MODEL_NAME=
LOCAL_AI_TIMEOUT_SECONDS=300
LOCAL_AI_CONNECT_TIMEOUT_SECONDS=30
LOCAL_AI_READ_TIMEOUT_SECONDS=300
LOCAL_AI_MAX_IMAGES=8
LOCAL_AI_MAX_TOKENS=4096
LOCAL_AI_DISABLE_THINKING=true
LOCAL_AI_STREAMING_ENABLED=false
AI_WORKER_SHARED_TOKEN=
ENABLE_IMAGE_PREPROCESSING=true
ENABLE_CENTERING_DETECTION=true
ENABLE_MANUAL_CENTERING_CORRECTION=true
ENABLE_TWO_PHASE_AI_GRADING=true
SEND_DIAGNOSTIC_IMAGES_TO_AI=true
AI_MAX_CONTEXT_TOKENS=10000
AI_PHASE_A_MAX_OUTPUT_TOKENS=1500
AI_PHASE_B_MAX_OUTPUT_TOKENS=2500

CARD_RECOGNITION_TOP_K=10
CARD_RECOGNITION_MIN_SCORE=30

PRICE_FETCH_ENABLED=true
PRICE_REFRESH_ENABLED=false
PRICE_REFRESH_INTERVAL_HOURS=24
PRICE_DEFAULT_CURRENCY=HUF
PRICE_RATE_LIMIT_SECONDS=3
PRICE_REQUEST_TIMEOUT_SECONDS=30
PRICE_SOURCES=manual,local_json,poketrace,tcgdex,pokemontcg
PRICE_FETCH_AFTER_RECOGNITION=false
PRICE_FX_EUR_HUF=
PRICE_FX_USD_HUF=
FX_CONVERSION_ENABLED=true
FX_DEFAULT_TARGET_CURRENCY=HUF
FX_PROVIDER=frankfurter
FX_PROVIDER_BASE_URL=https://api.frankfurter.dev/v2
FX_PROVIDER_FALLBACK_BASE_URL=https://api.frankfurter.dev/v1
FX_USER_AGENT=CardGrader/1.0
FX_CACHE_TTL_HOURS=12
FX_TIMEOUT_SECONDS=15
FX_FALLBACK_TO_STATIC_RATES=true
PRICE_PROVIDER_CACHE_TTL_HOURS=24
PRICE_EXTERNAL_FETCH_ENABLED=true
PRICE_PROVIDER_MIN_MATCH_SCORE=70

# Provider secrets can also be configured through the UI.
# UI-stored provider settings are saved in the backend database under /app/data and override env values.
# For encrypted provider secret storage, set CONFIG_ENCRYPTION_KEY and keep it stable/backed up.
# If you intentionally allow local-only plaintext secret storage, set ALLOW_UNENCRYPTED_PROVIDER_SECRETS=true.
CONFIG_ENCRYPTION_KEY=
ALLOW_UNENCRYPTED_PROVIDER_SECRETS=false

POKETRACE_ENABLED=false
POKETRACE_API_KEY=
POKETRACE_BASE_URL=https://api.poketrace.com/v1
POKETRACE_MARKET=US
POKETRACE_PLAN=free
POKETRACE_DAILY_LIMIT=250
POKETRACE_BURST_LIMIT=1
POKETRACE_BURST_WINDOW_SECONDS=2
POKETRACE_TIMEOUT_SECONDS=30
POKETRACE_CACHE_TTL_HOURS=24
POKETRACE_MIN_MATCH_SCORE=70
POKETRACE_FETCH_HISTORY=false
POKETRACE_HISTORY_PERIOD=30d
POKETRACE_RESPECT_RETRY_AFTER=true

TCGDEX_ENABLED=false
TCGDEX_BASE_URL=https://api.tcgdex.net/v2
TCGDEX_TIMEOUT_SECONDS=30
TCGDEX_RATE_LIMIT_SECONDS=2
TCGDEX_MIN_MATCH_SCORE=70

POKEMONTCG_ENABLED=false
POKEMONTCG_API_KEY=
POKEMONTCG_BASE_URL=https://api.pokemontcg.io/v2
POKEMONTCG_TIMEOUT_SECONDS=30
POKEMONTCG_RATE_LIMIT_SECONDS=2
POKEMONTCG_MIN_MATCH_SCORE=70
