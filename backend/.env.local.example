APP_MODE=local
HOST=127.0.0.1
PORT=8710

DATA_DIR=data
MEDIA_DIR=media
CATALOG_DIR=catalog
LOG_DIR=logs
# DATABASE_URL is optional. If omitted, CardGrader uses DATA_DIR/cardgrader.db.

LOCAL_AI_MODE=server_local
LOCAL_AI_PROVIDER=lmstudio
LOCAL_AI_BASE_URL=http://127.0.0.1:1234/v1
LOCAL_AI_MODEL_NAME=<your-local-vision-model>
LOCAL_AI_TIMEOUT_SECONDS=120
LOCAL_AI_MAX_IMAGES=1
LOCAL_AI_MAX_TOKENS=4096
LOCAL_AI_DISABLE_THINKING=true
AI_WORKER_SHARED_TOKEN=
